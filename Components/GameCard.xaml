<UserControl x:Class="Lunex.Components.GameCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:services="clr-namespace:Lunex.Services"
             mc:Ignorable="d" 
             d:DesignHeight="284" d:DesignWidth="284"
             Cursor="Hand"
             MouseLeftButtonUp="OnCardClick">
    <UserControl.Resources>
        <!-- Card Hover Animations -->
        <Storyboard x:Key="OnMouseEnter">
            <DoubleAnimation Storyboard.TargetName="cardScale" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.18" DecelerationRatio="0.5"/>
            <DoubleAnimation Storyboard.TargetName="cardScale" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.18" DecelerationRatio="0.5"/>
            <DoubleAnimation Storyboard.TargetName="iconScale" Storyboard.TargetProperty="ScaleX" To="1.5" Duration="0:0:0.18" DecelerationRatio="0.5"/>
            <DoubleAnimation Storyboard.TargetName="iconScale" Storyboard.TargetProperty="ScaleY" To="1.5" Duration="0:0:0.18" DecelerationRatio="0.5"/>
        </Storyboard>
        <Storyboard x:Key="OnMouseLeave">
            <DoubleAnimation Storyboard.TargetName="cardScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.18" AccelerationRatio="0.5"/>
            <DoubleAnimation Storyboard.TargetName="cardScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.18" AccelerationRatio="0.5"/>
            <DoubleAnimation Storyboard.TargetName="iconScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.18" AccelerationRatio="0.5"/>
            <DoubleAnimation Storyboard.TargetName="iconScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.18" AccelerationRatio="0.5"/>
        </Storyboard>

        <Style x:Key="GameCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#1F1F22"/>
            <Setter Property="BorderBrush" Value="#1CFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="12" Opacity="0.25" ShadowDepth="4"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Glow Borders is Enabled AND Mouse is Over -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Source={x:Static services:SettingsService.Instance}, Path=EnableGlowBorders}" Value="True"/>
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="BorderBrush" Value="#C3C0FF"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#4F46E5" BlurRadius="25" Opacity="0.65" ShadowDepth="0"/>
                        </Setter.Value>
                    </Setter>
                </MultiDataTrigger>
                
                <!-- Glow Borders is Disabled AND Mouse is Over -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Source={x:Static services:SettingsService.Instance}, Path=EnableGlowBorders}" Value="False"/>
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#000000" BlurRadius="20" Opacity="0.4" ShadowDepth="4"/>
                        </Setter.Value>
                    </Setter>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <UserControl.RenderTransform>
        <ScaleTransform x:Name="cardScale" CenterX="142" CenterY="142"/>
    </UserControl.RenderTransform>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="MouseEnter">
            <BeginStoryboard Storyboard="{StaticResource OnMouseEnter}"/>
        </EventTrigger>
        <EventTrigger RoutedEvent="MouseLeave">
            <BeginStoryboard Storyboard="{StaticResource OnMouseLeave}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Border x:Name="CardBorder" Style="{StaticResource GameCardBorderStyle}">

        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <!-- 70% Cover Image -->
                <RowDefinition Height="7*"/>
                <!-- 30% Metadata bar -->
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>

            <!-- Background Cover Banner -->
            <Grid x:Name="FallbackBanner" Grid.Row="0">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#224F46E5" Offset="0"/>
                        <GradientStop Color="#227C03D3" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <!-- Glowing controller path fallback -->
                <Path Data="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm3-3c-.83 0-1.5-.67-1.5-1.5S17.67 9 18.5 9s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z" 
                      Fill="#22C3C0FF" 
                      Width="80" Height="50" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <!-- Custom Cover Image Layer -->
            <Image x:Name="CoverImage" Grid.Row="0" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>

            <!-- Visual Overlay Gradients -->
            <Border Grid.Row="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Transparent" Offset="0.0"/>
                        <GradientStop Color="#99131316" Offset="0.5"/>
                        <GradientStop Color="#FA131316" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Bottom Content Metadata details -->
            <Border Grid.Row="1" Background="#0CFFFFFF" Padding="16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Game Icon next to Title -->
                    <Border x:Name="CardIconBorder" Grid.Column="0" Width="32" Height="32" CornerRadius="6" Background="#1AFFFFFF" BorderBrush="#1CFFFFFF" BorderThickness="1" Margin="0,0,10,0" VerticalAlignment="Center" ClipToBounds="True" RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="iconScale" ScaleX="1.0" ScaleY="1.0"/>
                        </Border.RenderTransform>
                        <Image x:Name="CardIconImage" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtTitle" Text="Game Title" Foreground="White" FontSize="13.5" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="TxtPlaytime" Text="0 hours played" Foreground="#7FC7C4D8" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
