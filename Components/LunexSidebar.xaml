<UserControl x:Class="Lunex.Components.LunexSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Lunex"
             xmlns:vm="clr-namespace:Lunex.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="260">
    <UserControl.Resources>
        <!-- Sidebar Rounded Dark Search Box Style -->
        <Style x:Key="SidebarSearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="#121212" />
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="32,8,12,8" />
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" VerticalAlignment="Center"/>
                            </Border>
                            <!-- Search Icon (Magnifying Glass) -->
                            <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                                  Fill="#6b7280" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <TextBlock x:Name="watermark"
                                       Text="{TemplateBinding Tag}"
                                       Foreground="#6b7280"
                                       Opacity="0.8"
                                       FontStyle="Normal"
                                       Visibility="Collapsed"
                                       IsHitTestVisible="False"
                                       Margin="32,0,0,0"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="watermark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="watermark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="border" Property="Background" Value="#161616" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <!-- Sidebar Flat ListBox Style -->
        <Style x:Key="SidebarListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0" Padding="0">
                            <ScrollViewer Focusable="false" Padding="0">
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar ListBoxItem Style -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="itemBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="{StaticResource PrimaryBrushLow}"/>
                                <Setter TargetName="itemBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="itemBorder" Property="BorderThickness" Value="2,0,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource SurfaceContainerBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Right Border line separator split -->
        <Border Grid.RowSpan="3" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="0,0,1,0" />

        <!-- 1. Top Controls Section (Search & Sort) -->
        <StackPanel Grid.Row="0" Margin="16,16,16,12" Orientation="Vertical">
            <!-- Search Text Box -->
            <TextBox Height="32" 
                     Style="{StaticResource SidebarSearchBox}"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Search by name..."
                     VerticalContentAlignment="Center"/>

            <!-- Sorting & Action Info -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- ComboBox matching steam filter dropdown -->
                <ComboBox Grid.Column="0" Height="28" 
                          SelectedValue="{Binding ActiveOption}"
                          SelectedValuePath="Tag"
                          FontSize="11"
                          Padding="8,2,24,2"
                          BorderThickness="0"
                          Background="Transparent"
                          VerticalContentAlignment="Center">
                    <ComboBoxItem Content="Recently Played" Tag="{x:Static vm:LibrarySortOption.RecentlyPlayed}"/>
                    <ComboBoxItem Content="Alphabetical" Tag="{x:Static vm:LibrarySortOption.All}"/>
                    <ComboBoxItem Content="Most Played" Tag="{x:Static vm:LibrarySortOption.MostPlayed}"/>
                </ComboBox>

                <!-- Small visual filter decal -->
                <Path Grid.Column="1" Data="M10 18h4v-2h-4v2zM3 6v2h18V6H3zm3 7h12v-2H6v2z" 
                      Fill="#6b7280" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0" IsHitTestVisible="False"/>
            </Grid>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="— ADDED GAMES" 
                       Foreground="#4b5563" 
                       FontSize="10" 
                       FontWeight="Bold" 
                       local:TypographyHelper.CharacterSpacing="100" 
                       Margin="16,0,16,8"/>

            <ListBox Grid.Row="1" 
                     ItemsSource="{Binding FilteredGames}"
                     Style="{StaticResource SidebarListBoxStyle}"
                     SelectionChanged="OnGameSelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Background="Transparent" Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="16" Height="16" CornerRadius="2" ClipToBounds="True" Background="#333" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Image Source="{Binding Converter={StaticResource GameToIconConverter}}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="LowQuality"/>
                            </Border>

                            <TextBlock Grid.Column="1" 
                                       Text="{Binding Title}" 
                                       FontSize="13" 
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#9ca3af"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Foreground" Value="#5cff5c"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsInstalling}" Value="True">
                                                <Setter Property="Foreground" Value="#1A9FFF"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True"/>
                                                    <Condition Binding="{Binding IsRunning}" Value="False"/>
                                                    <Condition Binding="{Binding IsInstalling}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="White"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True"/>
                                                    <Condition Binding="{Binding IsRunning}" Value="False"/>
                                                    <Condition Binding="{Binding IsInstalling}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="White"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Border Grid.Row="2" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="0,1,0,0" Background="{StaticResource SurfaceContainerLowBrush}" Padding="16,12">
            <Button Command="{Binding AddGameCommand}" Height="36" HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" Fill="White" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" x:Name="plusIcon"/>
                            <TextBlock Text="Add a Game" Foreground="White" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" x:Name="btnText"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="plusIcon" Property="Fill" Value="White"/>
                                <Setter TargetName="btnText" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Border>
    </Grid>
</UserControl>
