<UserControl x:Class="Lunex.Components.LunexSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="260">
    <UserControl.Resources>
        <!-- Sidebar Button Styles -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C7C4D8"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="16,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="itemBorder" 
                                CornerRadius="8" 
                                Background="Transparent" 
                                BorderThickness="1" 
                                BorderBrush="Transparent"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <!-- Active Indicator Line -->
                                <Border x:Name="indicator"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Width="4"
                                        Height="0"
                                        Margin="4,0,0,0"
                                        CornerRadius="2"
                                        Background="#C3C0FF">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#C3C0FF" BlurRadius="8" Opacity="0.5" ShadowDepth="0"/>
                                    </Border.Effect>
                                </Border>
                                
                                <!-- Content Presenter -->
                                <ContentPresenter Margin="24,0,16,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#08FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Active">
                                <Setter TargetName="itemBorder" Property="Background" Value="#14C3C0FF"/>
                                <Setter TargetName="itemBorder" Property="BorderBrush" Value="#26C3C0FF"/>
                                <Setter TargetName="indicator" Property="Height" Value="20"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#66131316">
        <!-- Draggable Title Bar handles in parent window, right border line splits columns -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="3" BorderBrush="#14FFFFFF" BorderThickness="0,0,1,0"/>

        <!-- Top Profile Badge Section -->
        <StackPanel Grid.Row="0" Margin="20,24,20,32" Orientation="Horizontal">
            <!-- Biometric Decal / Avatar Fallback -->
            <Grid Width="40" Height="40">
                <Border CornerRadius="20" BorderBrush="#40C3C0FF" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4F46E5" Offset="0"/>
                            <GradientStop Color="#7C03D3" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <!-- Initials Typewriter Fallback -->
                <TextBlock x:Name="InitialsBlock"
                           Text="NS" 
                           Foreground="White" 
                           FontWeight="Black" 
                           FontSize="12" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
                <!-- Profile Image layer -->
                <Ellipse x:Name="ProfileEllipse" Width="40" Height="40" Visibility="Collapsed">
                    <Ellipse.Fill>
                        <ImageBrush x:Name="ProfileImageBrush" Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>
            </Grid>
            
            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="UsernameBlock" Text="Lunex Shell" Foreground="#C3C0FF" FontSize="14" FontWeight="Bold"/>
                <TextBlock x:Name="RankBlock" Text="THE SILENT COMMANDER" Foreground="#66C7C4D8" FontSize="8" FontWeight="SemiBold" Margin="0,2,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- Navigation Lists Section -->
        <StackPanel Grid.Row="1" Orientation="Vertical">
            <Button x:Name="BtnLibrary" Style="{StaticResource SidebarButtonStyle}" Click="NavigateLibrary">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M3 5v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2zm12 4c0 1.66-1.34 3-3 3s-3-1.34-3-3 1.34-3 3-3 3 1.34 3 3zm-9 9c0-2 4-3.1 6-3.1s6 1.1 6 3.1v1H6v-1z" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                          Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                    <TextBlock Text="Library" Margin="16,0,0,0" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            
            <Button x:Name="BtnMusic" Style="{StaticResource SidebarButtonStyle}" Click="NavigateMusic">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                          Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                    <TextBlock Text="Music" Margin="16,0,0,0" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnStats" Style="{StaticResource SidebarButtonStyle}" Click="NavigateStats">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                          Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                    <TextBlock Text="Stats" Margin="16,0,0,0" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnProfile" Style="{StaticResource SidebarButtonStyle}" Click="NavigateProfile">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                          Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                    <TextBlock Text="Profile" Margin="16,0,0,0" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Bottom Settings Section -->
        <Button Grid.Row="2" x:Name="BtnSettings" Style="{StaticResource SidebarButtonStyle}" Margin="16,0,16,24" Click="NavigateSettings">
            <StackPanel Orientation="Horizontal">
                <Path Data="M19.43 12.98c.04-.32.07-.64.07-.98s-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98s.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z" 
                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                      Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                <TextBlock Text="Settings" Margin="16,0,0,0" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
