<Window x:Class="Lunex.Views.GameOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Game Options"
        Height="265" Width="330"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- Scale and fade in animation on load -->
        <Storyboard x:Key="OnLoadedStoryboard">
            <DoubleAnimation Storyboard.TargetName="DialogBorder" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="DialogScale" Storyboard.TargetProperty="ScaleX"
                             From="0.8" To="1.0" Duration="0:0:0.3" DecelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetName="DialogScale" Storyboard.TargetProperty="ScaleY"
                             From="0.8" To="1.0" Duration="0:0:0.3" DecelerationRatio="0.8"/>
        </Storyboard>

        <!-- Scale and fade out animation on close -->
        <Storyboard x:Key="OnClosingStoryboard">
            <DoubleAnimation Storyboard.TargetName="DialogBorder" Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.2" AccelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetName="DialogScale" Storyboard.TargetProperty="ScaleX"
                             To="0.8" Duration="0:0:0.2" AccelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetName="DialogScale" Storyboard.TargetProperty="ScaleY"
                             To="0.8" Duration="0:0:0.2" AccelerationRatio="0.8"/>
        </Storyboard>

        <!-- Red Warning Button Style -->
        <Style x:Key="WarningButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="glowBorder"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="#33FFFFFF">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="{StaticResource ErrorColor}" Offset="0.0"/>
                                    <GradientStop Color="#D05F5F" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect x:Name="btnGlow" Color="{StaticResource ErrorColor}" BlurRadius="8" Opacity="0.25" ShadowDepth="1.5"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="glowBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource ErrorColor}" BlurRadius="12" Opacity="0.45" ShadowDepth="2"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="glowBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="glowBorder" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Gray Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#99C7C4D8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#0FFFFFFF"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="#44FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#05FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource OnLoadedStoryboard}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border x:Name="DialogBorder" CornerRadius="16" BorderBrush="#1DFFFFFF" BorderThickness="1.5" Background="{StaticResource CyberBackgroundGradient}" ClipToBounds="True" RenderTransformOrigin="0.5,0.5" Opacity="0">
        <Border.RenderTransform>
            <ScaleTransform x:Name="DialogScale" ScaleX="0.8" ScaleY="0.8"/>
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <!-- Title Row -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons Content Row -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Drag Bar -->
            <Grid Grid.Row="0" Margin="24,20,24,12" MouseLeftButtonDown="DragWindow">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" 
                          Fill="{StaticResource PrimaryBrush}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TitleText" Text="GAME OPTIONS" Foreground="{StaticResource PrimaryBrush}" FontSize="10" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Click="Cancel_Click" Style="{StaticResource ModalCloseButtonStyle}">
                    <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                          Width="10" Height="10" Stretch="Uniform"/>
                </Button>
            </Grid>

            <!-- Buttons Stack -->
            <StackPanel Grid.Row="1" Margin="24,4,24,16" Orientation="Vertical">
                <!-- Play Game Button -->
                <Button Click="Play_Click" Height="40" Width="280" HorizontalAlignment="Center" Style="{StaticResource NeonButtonStyle}" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Path Data="M8 5v14l11-7z" Fill="White" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                        <TextBlock Text="PLAY GAME" FontSize="11.5" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                 <!-- Customize Button -->
                 <Button Click="Customize_Click" Height="40" Width="280" HorizontalAlignment="Center" Style="{StaticResource NeonButtonStyle}" Margin="0,0,0,10">
                     <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                         <!-- Gear icon -->
                         <Path Data="M19.43 12.98c.04-.32.07-.64.07-.98s-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98s.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z" 
                               Fill="White" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                         <TextBlock Text="CUSTOMIZE PROPERTIES" FontSize="11.5" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                     </StackPanel>
                 </Button>

                <!-- Remove Button -->
                <Button Click="Remove_Click" Height="40" Width="280" HorizontalAlignment="Center" Style="{StaticResource WarningButtonStyle}" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" 
                              Fill="White" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                        <TextBlock Text="REMOVE FROM LIBRARY" FontSize="11.5" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Cancel Button -->
                <Button Click="Cancel_Click" Content="CANCEL" Height="34" Width="280" HorizontalAlignment="Center" Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
