<Window x:Class="Lunex.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lunex.Views"
        mc:Ignorable="d"
        Title="Lunex Login" 
        Width="450"
        SizeToContent="Height"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Standard Button Style for Ghost/Secondary -->
        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,8"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Link Button Style (No padding) -->
        <Style x:Key="LinkButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input Icon Button Style (For icons on white backgrounds) -->
        <Style x:Key="InputIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Orange Primary Button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF4500"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,12"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF5722"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E63E00"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#55FF4500"/>
                                <Setter Property="Foreground" Value="#88FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Outline Button for Google -->
        <Style x:Key="OutlineButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,12"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#11FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input Style -->
        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="40,0,40,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label Style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Border Background="#161616" CornerRadius="8" BorderBrush="#333333" BorderThickness="1">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Close Button Top Right -->
            <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Width="30" Height="30" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Skip_Click">
                <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" Fill="#9CA3AF" Width="12" Height="12" Stretch="Uniform"/>
            </Button>

            <!-- Header -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,16">
                <TextBlock Text="LUNEX" Foreground="#FF4500" FontSize="36" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                
                <TextBlock Text="Login to never lose your game progress" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,4" TextWrapping="Wrap"/>
                
                <TextBlock Text="Sync your saves, achievements, and library across all devices." Foreground="#9CA3AF" FontSize="13" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="300"/>
            </StackPanel>

            <!-- Form -->
            <StackPanel Grid.Row="2" Margin="0,0,0,0">
                <!-- Status Message -->
                <TextBlock x:Name="StatusMessage" Foreground="#FF4500" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,12" TextWrapping="Wrap" Visibility="Collapsed"/>

                <!-- Email -->
                <TextBlock Text="EMAIL ADDRESS" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,12">
                    <TextBox x:Name="EmailInput" Height="40" Padding="40,0,12,0" VerticalContentAlignment="Center" Background="White" Foreground="Black" BorderThickness="0" FontSize="14" Style="{StaticResource InputStyle}" TextChanged="Input_Changed"/>
                    <TextBlock x:Name="EmailPlaceholder" Text="agent@nexusrealm.in" Foreground="#9CA3AF" IsHitTestVisible="False" VerticalAlignment="Center" Margin="40,0,0,0" FontSize="14"/>
                    <Path Data="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" 
                          Fill="#9CA3AF" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Left" Margin="12,0,0,0"/>
                </Grid>

                <!-- Username (Sign Up Only) -->
                <StackPanel x:Name="UsernameSection" Visibility="Collapsed">
                    <TextBlock Text="USERNAME" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,12">
                        <TextBox x:Name="UsernameInput" Height="40" Padding="40,0,12,0" VerticalContentAlignment="Center" Background="White" Foreground="Black" BorderThickness="0" FontSize="14" Style="{StaticResource InputStyle}" TextChanged="Input_Changed"/>
                        <TextBlock x:Name="UsernamePlaceholder" Text="AgentSmith" Foreground="#9CA3AF" IsHitTestVisible="False" VerticalAlignment="Center" Margin="40,0,0,0" FontSize="14"/>
                        <Path Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" 
                              Fill="#9CA3AF" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Left" Margin="12,0,0,0"/>
                    </Grid>
                </StackPanel>

                <!-- Password -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="PASSWORD" Style="{StaticResource LabelStyle}" Margin="0"/>
                    <Button x:Name="ForgotButton" Grid.Column="1" Content="Forgot?" Style="{StaticResource LinkButtonStyle}" FontSize="11"/>
                </Grid>
                <Grid Margin="0,0,0,12">
                    <PasswordBox x:Name="PasswordInput" Height="40" Padding="40,0,40,0" VerticalContentAlignment="Center" Background="White" Foreground="Black" BorderThickness="0" FontSize="14" Style="{StaticResource InputStyle}" PasswordChanged="PasswordInput_Changed"/>
                    <TextBox x:Name="PasswordVisibleInput" Height="40" Padding="40,0,40,0" VerticalContentAlignment="Center" Background="White" Foreground="Black" BorderThickness="0" FontSize="14" Style="{StaticResource InputStyle}" TextChanged="Input_Changed" Visibility="Collapsed"/>
                    <TextBlock x:Name="PasswordPlaceholder" Text="••••••••" Foreground="#9CA3AF" IsHitTestVisible="False" VerticalAlignment="Center" Margin="40,0,0,0" FontSize="14"/>
                    
                    <Path Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" 
                          Fill="#9CA3AF" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Left" Margin="12,0,0,0"/>
                    <!-- Eye Toggle -->
                    <Button HorizontalAlignment="Right" Width="30" Height="30" Margin="0,0,8,0" Style="{StaticResource InputIconButtonStyle}" Click="TogglePassword_Click" ToolTip="Toggle Visibility">
                        <Path x:Name="PasswordEyeIcon" Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" 
                              Fill="{Binding Path=Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Button}}}" Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                </Grid>

                <!-- Confirm Password (Sign Up Only) -->
                <StackPanel x:Name="ConfirmPasswordSection" Visibility="Collapsed">
                    <TextBlock Text="CONFIRM PASSWORD" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,12">
                        <PasswordBox x:Name="ConfirmPasswordInput" Height="40" Padding="40,0,40,0" VerticalContentAlignment="Center" Background="White" Foreground="Black" BorderThickness="0" FontSize="14" Style="{StaticResource InputStyle}" PasswordChanged="PasswordInput_Changed"/>
                        <TextBox x:Name="ConfirmPasswordVisibleInput" Height="40" Padding="40,0,40,0" VerticalContentAlignment="Center" Background="White" Foreground="Black" BorderThickness="0" FontSize="14" Style="{StaticResource InputStyle}" TextChanged="Input_Changed" Visibility="Collapsed"/>
                        <TextBlock x:Name="ConfirmPasswordPlaceholder" Text="••••••••" Foreground="#9CA3AF" IsHitTestVisible="False" VerticalAlignment="Center" Margin="40,0,0,0" FontSize="14"/>
                        <Path Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" 
                              Fill="#9CA3AF" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Left" Margin="12,0,0,0"/>
                        <!-- Eye Toggle -->
                        <Button HorizontalAlignment="Right" Width="30" Height="30" Margin="0,0,8,0" Style="{StaticResource InputIconButtonStyle}" Click="ToggleConfirmPassword_Click" ToolTip="Toggle Visibility">
                            <Path x:Name="ConfirmPasswordEyeIcon" Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" 
                                  Fill="{Binding Path=Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Button}}}" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                    </Grid>
                </StackPanel>

                <Button x:Name="LoginButton" Content="Log In ➔" Style="{StaticResource PrimaryButtonStyle}" Click="MainAction_Click" Margin="0,4,0,16"/>
                
                <Button x:Name="ToggleModeButton" Content="Need an account? Sign Up" Style="{StaticResource LinkButtonStyle}" Click="ToggleMode_Click" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Divider -->
            <Grid x:Name="OrDivider" Grid.Row="3" Margin="0,16,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Rectangle Grid.Column="0" Height="1" Fill="#333333" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="OR" Foreground="#9CA3AF" FontSize="11" FontWeight="Bold" Margin="12,0"/>
                <Rectangle Grid.Column="2" Height="1" Fill="#333333" VerticalAlignment="Center"/>
            </Grid>

            <!-- Bottom Actions -->
            <StackPanel Grid.Row="4" VerticalAlignment="Bottom" Margin="0,0,0,20">
                <Button x:Name="GoogleButton" Style="{StaticResource OutlineButtonStyle}" Click="Google_Click" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                            <Canvas Width="24" Height="24">
                                <Path Data="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" Fill="#4285F4"/>
                                <Path Data="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" Fill="#34A853"/>
                                <Path Data="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" Fill="#FBBC05"/>
                                <Path Data="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" Fill="#EA4335"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Continue with Google" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Content="SKIP FOR NOW" Style="{StaticResource GhostButtonStyle}" Click="Skip_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
