<Window x:Class="Lunex.Views.GameCustomizeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:components="clr-namespace:Lunex.Components"
        mc:Ignorable="d"
        Title="Customize Game"
        Height="460" Width="550"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Scale and fade in animation on load -->
        <Storyboard x:Key="OnLoadedStoryboard">
            <DoubleAnimation Storyboard.TargetName="DialogBorder" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="DialogScale" Storyboard.TargetProperty="ScaleX"
                             From="0.8" To="1.0" Duration="0:0:0.3" DecelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetName="DialogScale" Storyboard.TargetProperty="ScaleY"
                             From="0.8" To="1.0" Duration="0:0:0.3" DecelerationRatio="0.8"/>
        </Storyboard>

        <!-- Scale and fade out animation on close -->
        <Storyboard x:Key="OnClosingStoryboard">
            <DoubleAnimation Storyboard.TargetName="DialogBorder" Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.2" AccelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetName="DialogScale" Storyboard.TargetProperty="ScaleX"
                             To="0.8" Duration="0:0:0.2" AccelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetName="DialogScale" Storyboard.TargetProperty="ScaleY"
                             To="0.8" Duration="0:0:0.2" AccelerationRatio="0.8"/>
        </Storyboard>

        <!-- Ghost action button style -->
        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#99C7C4D8"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#0FFFFFFF"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="#44FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#05FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Cancel/Close Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#99C7C4D8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#0FFFFFFF"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="#44FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#05FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource OnLoadedStoryboard}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border x:Name="DialogBorder" CornerRadius="16" BorderBrush="#1DFFFFFF" BorderThickness="1.5" Background="{StaticResource CyberBackgroundGradient}" ClipToBounds="True" RenderTransformOrigin="0.5,0.5" Opacity="0">
        <Border.RenderTransform>
            <ScaleTransform x:Name="DialogScale" ScaleX="0.8" ScaleY="0.8"/>
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <!-- Title Row -->
                <RowDefinition Height="Auto"/>
                <!-- Scrollable Content Row -->
                <RowDefinition Height="*"/>
                <!-- Bottom Action Row -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Drag Bar -->
            <Grid Grid.Row="0" Margin="24,20,24,12" MouseLeftButtonDown="DragWindow">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Path Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" 
                          Fill="{StaticResource PrimaryBrush}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TitleText" Text="CUSTOMIZE PROPERTIES" Foreground="{StaticResource PrimaryBrush}" FontSize="10" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Click="Cancel_Click" Style="{StaticResource ModalCloseButtonStyle}">
                    <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                          Width="10" Height="10" Stretch="Uniform"/>
                </Button>
            </Grid>

            <!-- Content Panel -->
            <Grid Grid.Row="1" Margin="24,8">
                <Grid.RowDefinitions>
                    <!-- Game Title edit -->
                    <RowDefinition Height="Auto"/>
                    <!-- Custom elements grid -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Game Title Section -->
                <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,16">
                    <TextBlock Text="GAME TITLE" Foreground="#66C7C4D8" FontSize="8.5" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtGameTitle" Style="{StaticResource SunkenSearchBox}" Height="38" VerticalContentAlignment="Center" CaretBrush="{StaticResource PrimaryBrush}"/>
                </StackPanel>

                <!-- Custom Elements Column Layout -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <!-- Cover image side -->
                        <ColumnDefinition Width="*"/>
                        <!-- Splitter -->
                        <ColumnDefinition Width="24"/>
                        <!-- Icon side -->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cover image group -->
                    <Border Grid.Column="0" BorderBrush="#1CFFFFFF" BorderThickness="1" CornerRadius="12" Background="#0CFFFFFF" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="COVER IMAGE" Foreground="{StaticResource PrimaryBrush}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            
                            <!-- Cover Preview -->
                            <Border Grid.Row="1" Width="120" Height="140" CornerRadius="8" Background="#11FFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" ClipToBounds="True">
                                <Grid>
                                    <Image x:Name="CoverPreview" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <!-- Fallback symbol -->
                                    <Path x:Name="CoverFallbackIcon" Data="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm3-3c-.83 0-1.5-.67-1.5-1.5S17.67 9 18.5 9s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z" 
                                          Fill="#22FFFFFF" Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                <Button Click="BrowseCover_Click" Content="BROWSE" Style="{StaticResource GhostButtonStyle}" Padding="12,6" Margin="0,0,8,0"/>
                                <Button Click="ClearCover_Click" Content="RESET" Style="{StaticResource GhostButtonStyle}" Padding="12,6"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Icon image group -->
                    <Border Grid.Column="2" BorderBrush="#1CFFFFFF" BorderThickness="1" CornerRadius="12" Background="#0CFFFFFF" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="GAME ICON" Foreground="{StaticResource PrimaryBrush}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,12"/>

                            <!-- Icon Preview -->
                            <Border Grid.Row="1" Width="90" Height="90" CornerRadius="8" Background="#11FFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" ClipToBounds="True" VerticalAlignment="Center">
                                <Grid>
                                    <Image x:Name="IconPreview" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <!-- Fallback symbol -->
                                    <Path x:Name="IconFallbackIcon" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" 
                                          Fill="#22FFFFFF" Width="36" Height="36" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                <Button Click="BrowseIcon_Click" Content="BROWSE" Style="{StaticResource GhostButtonStyle}" Padding="12,6" Margin="0,0,8,0"/>
                                <Button Click="ClearIcon_Click" Content="RESET" Style="{StaticResource GhostButtonStyle}" Padding="12,6"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </Grid>
            </Grid>

            <!-- Action buttons container -->
            <Border Grid.Row="2" Background="#0CFFFFFF" BorderBrush="#0BFFFFFF" BorderThickness="0,1,0,0" Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Click="Save_Click" Height="38" Style="{StaticResource NeonButtonStyle}">
                        <TextBlock Text="SAVE CHANGES" FontSize="11" FontWeight="Bold" />
                    </Button>
                    <Button Grid.Column="2" Click="Cancel_Click" Height="38" Style="{StaticResource SecondaryButtonStyle}">
                        <TextBlock Text="CANCEL" FontSize="11" FontWeight="Bold"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
