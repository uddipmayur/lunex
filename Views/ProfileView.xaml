<UserControl x:Class="Lunex.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:components="clr-namespace:Lunex.Components"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <!-- Slide-in from left and fade-in loaded transition -->
        <Storyboard x:Key="OnLoadedStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-40" To="0" Duration="0:0:0.4" DecelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35"/>
        </Storyboard>

        <!-- Ghost action button style (for secondary actions like Reset/Browse) -->
        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#99C7C4D8"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="7"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#0FFFFFFF"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="#44FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#05FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.RenderTransform>
        <TranslateTransform X="-40"/>
    </UserControl.RenderTransform>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource OnLoadedStoryboard}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid Background="Transparent">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical" Margin="32,24,32,48">
                
                <!-- 1. Header Bar -->
                <StackPanel Orientation="Vertical" Margin="0,0,0,32">
                    <TextBlock Text="Profile" Foreground="White" FontSize="28" FontWeight="ExtraBold" />
                    <TextBlock Text="MANAGE YOUR PROFILE DETAILS &amp; SECURITY CREDENTIALS" Foreground="{StaticResource PrimaryBrushHigh}" FontSize="12" FontWeight="Bold"  Margin="0,4,0,0"/>
                </StackPanel>

                <!-- 2. Bento Columns Grid -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Customizer Fields -->
                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        
                        <!-- Inputs Panel -->
                        <components:GlassPanel CornerRadius="12" Padding="24">
                            <StackPanel Orientation="Vertical">
                                <!-- Title Header -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Path Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" 
                                          Fill="{StaticResource PrimaryBrush}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Text="PROFILE DETAILS" Foreground="{StaticResource PrimaryBrush}" FontSize="13" FontWeight="Bold"  Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Username codename Input -->
                                <TextBlock Text="USERNAME / CODENAME" Foreground="{StaticResource OnSurfaceVariantBrushHigh}" FontSize="12" FontWeight="Bold"  Margin="0,0,0,8"/>
                                <TextBox Style="{StaticResource SunkenSearchBox}" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,24" Height="38" VerticalContentAlignment="Center"/>

                                <!-- Title Rank Input -->
                                <TextBlock Text="RANK" Foreground="{StaticResource OnSurfaceVariantBrushHigh}" FontSize="12" FontWeight="Bold"  Margin="0,0,0,8"/>
                                <Border Background="#0AFFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="4" Margin="0,0,0,24" Height="38">
                                    <TextBlock Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Foreground="#99C7C4D8" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0"/>
                                </Border>

                                <!-- Custom Profile Decal/Avatar -->
                                <TextBlock Text="CUSTOM PROFILE AVATAR" Foreground="{StaticResource OnSurfaceVariantBrushHigh}" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Style="{StaticResource SunkenSearchBox}" 
                                             Text="{Binding DecalFilenameText, Mode=OneWay}" 
                                             IsReadOnly="True" 
                                             Height="38" 
                                             VerticalContentAlignment="Center" 
                                             Margin="0,0,12,0"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Command="{Binding BrowseDecalCommand}" Content="BROWSE" Padding="16,0" Margin="0,0,8,0" Style="{StaticResource GhostButtonStyle}" Height="38" IsEnabled="{Binding IsNotBusy}"/>
                                        <Button Command="{Binding ClearDecalCommand}" Content="CLEAR" Padding="16,0" Style="{StaticResource GhostButtonStyle}" Height="38" Visibility="{Binding AvatarVisibility}" IsEnabled="{Binding IsNotBusy}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Neon Save button -->
                                <Button Command="{Binding SaveCommand}" Padding="24,12"
                                        Style="{StaticResource NeonButtonStyle}"
                                        IsEnabled="{Binding IsNotBusy}">
                                    <Grid>
                                        <TextBlock Text="SAVE PROFILE" FontSize="13" FontWeight="Bold" 
                                                   Visibility="{Binding IsNotBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        
                                        <StackPanel Orientation="Horizontal" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Path Data="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" 
                                                  Stroke="White" StrokeThickness="2" StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                                  Width="14" Height="14" Margin="0,0,8,0" RenderTransformOrigin="0.5,0.5">
                                                <Path.RenderTransform>
                                                    <RotateTransform/>
                                                </Path.RenderTransform>
                                                <Path.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Path.Triggers>
                                            </Path>
                                            <TextBlock Text="SAVING..." FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                
                                <Button Command="{Binding LinkCloudCommand}" Padding="24,12" Margin="0,16,0,0"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Visibility="{Binding IsNotCloudLinked, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Visible}"
                                        IsEnabled="{Binding IsNotBusy}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z" 
                                              Fill="{StaticResource PrimaryBrush}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="LINK CLOUD ACCOUNT" FontSize="13" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <!-- Cloud Linked State -->
                                <Border Margin="0,16,0,0" Padding="16,12" CornerRadius="8" Background="#0A4ade80" BorderBrush="#224ade80" BorderThickness="1"
                                        Visibility="{Binding IsCloudLinked, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" Fill="#4ade80" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="CLOUD CONNECTED" FontSize="13" FontWeight="Bold" Foreground="#4ade80" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="1" Command="{Binding LogoutCloudCommand}" Padding="16,6" Style="{StaticResource GhostButtonStyle}" Background="#11ff4b2b" BorderBrush="#22ff4b2b" IsEnabled="{Binding IsNotBusy}">
                                            <TextBlock Text="LOG OUT" FontSize="11" FontWeight="Bold" Foreground="#ff4b2b"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </components:GlassPanel>

                    </StackPanel>

                    <!-- Right: Holographic Live Preview Badge -->
                    <StackPanel Grid.Column="2" Orientation="Vertical">
                        <TextBlock Text="PROFILE BADGE PREVIEW" Foreground="{StaticResource PrimaryBrush}" FontSize="13" FontWeight="Bold"  Margin="0,0,0,12"/>
                        
                        <components:GlassPanel CornerRadius="16" Padding="24">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <!-- Circular Badge frame -->
                                <Border BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1.5" Width="110" Height="110" CornerRadius="55" Padding="6" Margin="0,16,0,24">
                                    <Grid>
                                        <Border CornerRadius="49" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1.5" Background="#242424" />
                                        <Ellipse Width="98" Height="98" Visibility="{Binding AvatarVisibility}" RenderOptions.BitmapScalingMode="HighQuality">
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding DpPath}" Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="{Binding Initials}" Foreground="White" FontSize="32" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding FallbackVisibility}"/>
                                    </Grid>
                                </Border>

                                <!-- Text credentials -->
                                <TextBlock Text="{Binding Username}" Foreground="White" FontSize="18" FontWeight="Black" HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="220" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Title}" Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="Bold" Margin="0,6,0,24"  HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="220" TextTrimming="CharacterEllipsis"/>

                            </StackPanel>
                        </components:GlassPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
