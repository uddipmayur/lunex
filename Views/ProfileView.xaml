<UserControl x:Class="Lunex.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:components="clr-namespace:Lunex.Components"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <!-- Slide-in from left and fade-in loaded transition -->
        <Storyboard x:Key="OnLoadedStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-40" To="0" Duration="0:0:0.4" DecelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35"/>
        </Storyboard>

        <!-- Ghost action button style (for secondary actions like Reset/Browse) -->
        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#99C7C4D8"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="7"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#0FFFFFFF"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="#44FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#05FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.RenderTransform>
        <TranslateTransform X="-40"/>
    </UserControl.RenderTransform>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource OnLoadedStoryboard}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid Background="Transparent">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical" Margin="32,24,32,48">
                
                <!-- 1. Header Bar -->
                <StackPanel Orientation="Vertical" Margin="0,0,0,32">
                    <TextBlock Text="Profile" Foreground="White" FontSize="36" FontWeight="ExtraBold" />
                    <TextBlock Text="MANAGE YOUR COMMANDER SPECS &amp; SECURITY CREDENTIALS" Foreground="#4CC3C0FF" FontSize="9" FontWeight="Bold"  Margin="0,4,0,0"/>
                </StackPanel>

                <!-- 2. Bento Columns Grid -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Customizer Fields -->
                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        
                        <!-- Inputs Panel -->
                        <components:GlassPanel CornerRadius="12" Padding="24">
                            <StackPanel Orientation="Vertical">
                                <!-- Title Header -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Path Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" 
                                          Fill="{StaticResource PrimaryBrush}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Text="PROFILE DETAILS" Foreground="{StaticResource PrimaryBrush}" FontSize="9.5" FontWeight="Bold"  Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Username codename Input -->
                                <TextBlock Text="CODENAME / USERNAME" Foreground="#66C7C4D8" FontSize="8.5" FontWeight="Bold"  Margin="0,0,0,8"/>
                                <TextBox Style="{StaticResource SunkenSearchBox}" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,24" Height="38" VerticalContentAlignment="Center"/>

                                <!-- Title Rank Input -->
                                <TextBlock Text="RANK / SECTOR SUBTITLE" Foreground="#66C7C4D8" FontSize="8.5" FontWeight="Bold"  Margin="0,0,0,8"/>
                                <TextBox Style="{StaticResource SunkenSearchBox}" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,24" Height="38" VerticalContentAlignment="Center"/>

                                <!-- Custom Profile Decal/Avatar -->
                                <TextBlock Text="CUSTOM PROFILE AVATAR" Foreground="#66C7C4D8" FontSize="8.5" FontWeight="Bold" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Style="{StaticResource SunkenSearchBox}" 
                                             Text="{Binding DecalFilenameText, Mode=OneWay}" 
                                             IsReadOnly="True" 
                                             Height="38" 
                                             VerticalContentAlignment="Center" 
                                             Margin="0,0,12,0"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Command="{Binding BrowseDecalCommand}" Content="BROWSE" Padding="16,0" Margin="0,0,8,0" Style="{StaticResource GhostButtonStyle}" Height="38"/>
                                        <Button Command="{Binding ClearDecalCommand}" Content="CLEAR" Padding="16,0" Style="{StaticResource GhostButtonStyle}" Height="38" Visibility="{Binding AvatarVisibility}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Neon Save button -->
                                <Button Command="{Binding SaveCommand}" Padding="24,12"
                                        Style="{StaticResource NeonButtonStyle}">
                                    <TextBlock Text="SAVE PROFILE" FontSize="11" FontWeight="Bold" />
                                </Button>
                            </StackPanel>
                        </components:GlassPanel>

                    </StackPanel>

                    <!-- Right: Holographic Live Preview Badge -->
                    <StackPanel Grid.Column="2" Orientation="Vertical">
                        <TextBlock Text="BADGE DEPLOYMENT HOLOGRAPH" Foreground="#664EDEA3" FontSize="9.5" FontWeight="Bold"  Margin="0,0,0,12"/>
                        
                        <components:GlassPanel CornerRadius="16" Padding="24">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <!-- Glowing Circular Badge frame with multi-layered neon glow -->
                                <Border BorderBrush="#26C3C0FF" BorderThickness="1.5" Width="110" Height="110" CornerRadius="55" Padding="6" Margin="0,16,0,24">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#C3C0FF" BlurRadius="20" Opacity="0.4" ShadowDepth="0"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Border CornerRadius="49" BorderBrush="#40C3C0FF" BorderThickness="1.5" Background="#11FFFFFF">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#7C03D3" BlurRadius="15" Opacity="0.5" ShadowDepth="0"/>
                                            </Border.Effect>
                                        </Border>
                                        <Ellipse Width="98" Height="98" Visibility="{Binding AvatarVisibility}">
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding DpPath}" Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="{Binding Initials}" Foreground="White" FontSize="32" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding FallbackVisibility}"/>
                                    </Grid>
                                </Border>

                                <!-- Text credentials -->
                                <TextBlock Text="{Binding Username}" Foreground="White" FontSize="18" FontWeight="Black" HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="220" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Title}" Foreground="{StaticResource PrimaryBrush}" FontSize="9" FontWeight="Bold" Margin="0,6,0,24"  HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="220" TextTrimming="CharacterEllipsis"/>

                            </StackPanel>
                        </components:GlassPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
