<UserControl x:Class="Lunex.Views.GameDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:components="clr-namespace:Lunex.Components"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="900">
    <UserControl.Resources>
        <!-- Slide-in from left and fade-in loaded transition -->
        <Storyboard x:Key="OnLoadedStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-40" To="0" Duration="0:0:0.4" DecelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35"/>
        </Storyboard>

        <!-- Custom Fallback Image Brush for Game Banner -->
        <Style x:Key="BannerImageStyle" TargetType="Image">
            <Style.Triggers>
                <Trigger Property="Source" Value="{x:Null}">
                    <!-- Custom drawing fallback -->
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <UserControl.RenderTransform>
        <TranslateTransform X="-40"/>
    </UserControl.RenderTransform>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource OnLoadedStoryboard}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid Background="Transparent">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">
                
                <!-- 1. Cinematic Hero Banner Panel -->
                <Grid Height="440" Background="#1B1B1E">
                    <!-- Banner Cover Image -->
                    <Image x:Name="BannerCover" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- Gradient overlays (Dark Slate Fade and Left Side Fade) -->
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0.5"/>
                                <GradientStop Color="#B2131316" Offset="0.8"/>
                                <GradientStop Color="#FF131316" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FA131316" Offset="0.0"/>
                                <GradientStop Color="#99131316" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- 3 Dots Options Button -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="32" Width="40" Height="40" Cursor="Hand" Click="OnOptionsClick" Panel.ZIndex="10">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder" CornerRadius="20" Background="#4D000000" BorderThickness="1" BorderBrush="#1CFFFFFF">
                                    <Path Data="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z" 
                                          Fill="White" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="#99000000"/>
                                        <Setter TargetName="btnBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Banner Details Info Overlay -->
                    <Grid Margin="32,0,32,24" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Vertical">
                            <!-- Back Button Chevron -->
                            <Button Command="{Binding BackCommand}" Width="40" Height="40" HorizontalAlignment="Left" Margin="0,0,0,24" Cursor="Hand" Background="#4D000000" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="20" Background="{TemplateBinding Background}">
                                            <!-- Chevron Arrow Left -->
                                            <Path Data="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z" Fill="White" Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>


                            <!-- Game Title & Icon Stack -->
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,20">
                                <!-- Game Icon image -->
                                <Border x:Name="GameIconBorder" Width="48" Height="48" CornerRadius="8" Background="#1AFFFFFF" BorderBrush="#1CFFFFFF" BorderThickness="1" Margin="0,0,16,0" VerticalAlignment="Center" ClipToBounds="True">
                                    <Image x:Name="GameIconImage" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Title}" Foreground="White" FontSize="40" FontWeight="Black" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Actions Row -->
                            <StackPanel Orientation="Horizontal">
                                <!-- Glowing PLAY Button -->
                                <Button Command="{Binding PlayCommand}" Padding="32,14"
                                        Style="{StaticResource NeonButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Play/Hourglass vector -->
                                        <Path Data="M8 5v14l11-7z" Fill="White" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="13" FontWeight="Bold" Margin="8,0,0,0"  VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Stats Blocks -->
                                <StackPanel Margin="32,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="PLAYTIME" Foreground="#7FC7C4D8" FontSize="9" FontWeight="Bold" />
                                    <TextBlock Text="{Binding FormattedPlayTime}" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,2,0,0"/>
                                </StackPanel>

                                <Border BorderBrush="#1AFFFFFF" BorderThickness="1,0,0,0" Margin="32,8" Width="1"/>

                                <StackPanel Margin="32,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="LAST PLAYED" Foreground="#7FC7C4D8" FontSize="9" FontWeight="Bold" />
                                    <TextBlock Text="{Binding FormattedLastPlayed}" Foreground="#C3C0FF" FontSize="16" FontWeight="Bold" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- 2. Bento Layout Grid Details -->
                <Grid Margin="32,8,32,48">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="7*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="5*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column details -->
                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <!-- Weekly Activity card -->
                        <components:GlassPanel CornerRadius="12" Padding="20">
                            <StackPanel Orientation="Vertical">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Weekly Activity" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                        <TextBlock Text="Hours played over the last 7 days" Foreground="#7FC7C4D8" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Path Grid.Column="1" Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z" 
                                          Fill="#66C7C4D8" Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"/>
                                </Grid>
                                
                                 <!-- Weekly custom charts bars -->
                                 <UniformGrid Rows="1" Columns="7" Height="120" Margin="0,32,0,0">
                                     <!-- Mon -->
                                     <Grid>
                                         <Border CornerRadius="4" Background="#1AFFFFFF" Width="24" Height="{Binding WeeklyActivityHeights[0]}" VerticalAlignment="Bottom" Margin="0,0,0,20"/>
                                         <TextBlock Text="M" Foreground="#66C7C4D8" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                                     </Grid>
                                     <!-- Tue -->
                                     <Grid>
                                         <Border CornerRadius="4" Background="#1AFFFFFF" Width="24" Height="{Binding WeeklyActivityHeights[1]}" VerticalAlignment="Bottom" Margin="0,0,0,20"/>
                                         <TextBlock Text="T" Foreground="#66C7C4D8" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                                     </Grid>
                                     <!-- Wed -->
                                     <Grid>
                                         <Border CornerRadius="4" Background="#1AFFFFFF" Width="24" Height="{Binding WeeklyActivityHeights[2]}" VerticalAlignment="Bottom" Margin="0,0,0,20"/>
                                         <TextBlock Text="W" Foreground="#66C7C4D8" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                                     </Grid>
                                     <!-- Thu -->
                                     <Grid>
                                         <Border CornerRadius="4" Background="#1AFFFFFF" Width="24" Height="{Binding WeeklyActivityHeights[3]}" VerticalAlignment="Bottom" Margin="0,0,0,20"/>
                                         <TextBlock Text="T" Foreground="#66C7C4D8" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                                     </Grid>
                                     <!-- Fri (Glowing primary accent) -->
                                     <Grid>
                                         <Border CornerRadius="4" Background="#C3C0FF" Width="24" Height="{Binding WeeklyActivityHeights[4]}" VerticalAlignment="Bottom" Margin="0,0,0,20">
                                             <Border.Effect>
                                                 <DropShadowEffect Color="#C3C0FF" BlurRadius="8" Opacity="0.5" ShadowDepth="0"/>
                                             </Border.Effect>
                                         </Border>
                                         <TextBlock Text="F" Foreground="#C3C0FF" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                                     </Grid>
                                     <!-- Sat -->
                                     <Grid>
                                         <Border CornerRadius="4" Background="#1AFFFFFF" Width="24" Height="{Binding WeeklyActivityHeights[5]}" VerticalAlignment="Bottom" Margin="0,0,0,20"/>
                                         <TextBlock Text="S" Foreground="#66C7C4D8" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                                     </Grid>
                                     <!-- Sun -->
                                     <Grid>
                                         <Border CornerRadius="4" Background="#1AFFFFFF" Width="24" Height="{Binding WeeklyActivityHeights[6]}" VerticalAlignment="Bottom" Margin="0,0,0,20"/>
                                         <TextBlock Text="S" Foreground="#66C7C4D8" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                                     </Grid>
                                 </UniformGrid>
                            </StackPanel>
                        </components:GlassPanel>

                    </StackPanel>

                    <!-- Right Column details -->
                    <StackPanel Grid.Column="2" Orientation="Vertical">
                        <!-- System Integration card -->
                        <components:GlassPanel CornerRadius="12" Padding="20">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="SYSTEM INTEGRATION" Foreground="#66C7C4D8" FontSize="9" FontWeight="Bold"  Margin="0,0,0,16"/>
                                <!-- Exe folder navigator button link -->
                                <Button Command="{Binding OpenDirectoryCommand}" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand" HorizontalContentAlignment="Stretch">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="8" Background="#06FFFFFF" BorderBrush="#0BFFFFFF" BorderThickness="1" Padding="8,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Path Grid.Column="0" Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" 
                                                          Fill="#B3C7C4D8" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                                                     <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                                         <TextBlock Text="Executable Directory" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                                         <TextBlock Text="{Binding ExePath}" Foreground="#4CC7C4D8" FontSize="8.5" FontFamily="{StaticResource MonospaceFont}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                     </StackPanel>
                                                     <!-- Arrow right -->
                                                     <Path Grid.Column="2" Data="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z" Fill="#4DC7C4D8" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"/>
                                                 </Grid>
                                             </Border>
                                         </ControlTemplate>
                                     </Button.Template>
                                 </Button>
                             </StackPanel>
                         </components:GlassPanel>
 
                         <!-- Launch Arguments Customizer -->
                         <components:GlassPanel CornerRadius="12" Padding="20" Margin="0,20,0,0">
                             <StackPanel Orientation="Vertical">
                                 <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                     <Path Data="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z" 
                                           Fill="#B3C7C4D8" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                     <TextBlock Text="LAUNCH ARGUMENTS" Foreground="#B3C7C4D8" FontSize="9" FontWeight="Bold"  Margin="8,0,0,0" VerticalAlignment="Center"/>
                                 </StackPanel>
 
                                 <!-- Custom parameter input bar -->
                                 <Border CornerRadius="8" Background="#1B1B1E" BorderBrush="#1CFFFFFF" BorderThickness="1" Padding="8,4">
                                     <Grid>
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*"/>
                                             <ColumnDefinition Width="Auto"/>
                                         </Grid.ColumnDefinitions>
                                         <!-- Editable Text parameter box -->
                                         <TextBox Grid.Column="0" Text="{Binding LaunchArguments, UpdateSourceTrigger=PropertyChanged}"
                                                  Background="Transparent" BorderThickness="0" Foreground="White" CaretBrush="{StaticResource PrimaryBrush}"
                                                  FontSize="11" FontFamily="{StaticResource MonospaceFont}" VerticalAlignment="Center" Padding="4"/>
                                         <!-- Save chevron disk -->
                                         <Button Grid.Column="1" Command="{Binding SaveArgsCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4" VerticalAlignment="Center">
                                             <Button.Template>
                                                 <ControlTemplate TargetType="Button">
                                                     <Path Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z" 
                                                           Fill="{StaticResource PrimaryBrush}" Width="16" Height="16" Stretch="Uniform"/>
                                                 </ControlTemplate>
                                             </Button.Template>
                                         </Button>
                                     </Grid>
                                 </Border>
                             </StackPanel>
                         </components:GlassPanel>
                     </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
