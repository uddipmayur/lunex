<UserControl x:Class="Lunex.Views.GameDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:components="clr-namespace:Lunex.Components"
             xmlns:local="clr-namespace:Lunex"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="900">
    <UserControl.Resources>
        <!-- Slide-in from left and fade-in loaded transition -->
        <Storyboard x:Key="OnLoadedStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-40" To="0" Duration="0:0:0.4" DecelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35"/>
        </Storyboard>

        <!-- Custom Fallback Image Brush for Game Banner -->
        <Style x:Key="BannerImageStyle" TargetType="Image">
            <Style.Triggers>
                <Trigger Property="Source" Value="{x:Null}">
                    <!-- Custom drawing fallback -->
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- System Integration Button Style -->
        <Style x:Key="SystemIntegrationButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="systemBtnBorder" CornerRadius="6" Background="#1A1A1A" BorderBrush="#444" BorderThickness="2,0,0,0" Padding="14,10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="systemBtnBorder" Property="Background" Value="#222"/>
                                <Setter TargetName="systemBtnBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Orange Gear Button Style -->
        <Style x:Key="OrangeGearButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBrushLow}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBrushMedium}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.RenderTransform>
        <TranslateTransform X="-40"/>
    </UserControl.RenderTransform>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource OnLoadedStoryboard}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid Background="Transparent">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">
                
                <!-- 1. Cinematic Hero Banner Panel -->
                <Grid Height="574" Background="#1B1B1E">
                    <!-- Banner Cover Image -->
                    <Image x:Name="BannerCover" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>

                    <!-- Gradient overlays (Dark Slate Fade and Left Side Fade) -->
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0.7"/>
                                <GradientStop Color="#CC121212" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#99121212" Offset="0.0"/>
                                <GradientStop Color="#1A121212" Offset="0.4"/>
                                <GradientStop Color="Transparent" Offset="0.8"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Banner Details Info Overlay -->
                    <Grid Margin="32,0,32,24" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Vertical">
                            <!-- Game Title & Icon Stack -->
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,20">
                                <!-- Game Icon image -->
                                <Border x:Name="GameIconBorder" Width="48" Height="48" CornerRadius="8" Background="#2A2A2A" BorderBrush="#3A3A3A" BorderThickness="1" Margin="0,0,16,0" VerticalAlignment="Center" ClipToBounds="True">
                                    <Image x:Name="GameIconImage" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <TextBlock Text="{Binding Title}"
                                           FontFamily="{StaticResource DefaultFont}"
                                           FontSize="38"
                                           FontWeight="Bold"
                                           local:TypographyHelper.CharacterSpacing="80"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Actions Row -->
                            <StackPanel Orientation="Horizontal">
                                <!-- Button + Progress Stack -->
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                    <!-- PLAY / INSTALL Button -->
                                    <Button Command="{Binding PlayCommand}"
                                            Style="{StaticResource PlayButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Play/Hourglass vector -->
                                            <Path Data="M8 5v14l11-7z" Fill="White" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding StatusText}" Margin="8,0,0,0" Foreground="White" local:TypographyHelper.CharacterSpacing="120" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <!-- Installation flat progress bar -->
                                    <ProgressBar Value="{Binding InstallProgress}" Minimum="0" Maximum="100" Height="4" Margin="0,6,0,0"
                                                 Background="#1AFFFFFF" Foreground="{StaticResource PrimaryBrush}" BorderThickness="0"
                                                 Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                                <!-- Stats Blocks -->
                                <StackPanel Margin="32,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="PLAYTIME" Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold" local:TypographyHelper.CharacterSpacing="150" />
                                    <TextBlock Text="{Binding FormattedPlayTime}" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,2,0,0"/>
                                </StackPanel>

                                <Border BorderBrush="#1AFFFFFF" BorderThickness="1,0,0,0" Margin="32,8" Width="1"/>

                                <StackPanel Margin="32,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="LAST PLAYED" Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold" local:TypographyHelper.CharacterSpacing="150" />
                                    <TextBlock Text="{Binding FormattedLastPlayed}" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- 2. Bento Layout Grid Details -->
                <Grid Margin="32,8,32,48">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="7*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="5*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column details -->
                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <!-- Weekly Activity card -->
                        <components:GlassPanel CornerRadius="12" Padding="20">
                            <StackPanel Orientation="Vertical">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Weekly Activity" Foreground="White" FontSize="17" FontWeight="Bold"/>
                                        <TextBlock Text="Hours played over the last 7 days" Foreground="#B3C7C4D8" FontSize="13.5" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Path Grid.Column="1" Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z" 
                                          Fill="{StaticResource OnSurfaceVariantBrushMedium}" Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"/>
                                </Grid>
                                
                                 <!-- Weekly custom charts bars -->
                                 <ItemsControl ItemsSource="{Binding WeeklyDays}" Height="120" Margin="0,32,0,0">
                                     <ItemsControl.ItemsPanel>
                                         <ItemsPanelTemplate>
                                             <UniformGrid Rows="1" Columns="7" />
                                         </ItemsPanelTemplate>
                                     </ItemsControl.ItemsPanel>
                                     <ItemsControl.ItemTemplate>
                                         <DataTemplate>
                                             <Grid>
                                                 <Border CornerRadius="4" Background="{Binding BarBrush}" Width="24" Height="{Binding Height}" VerticalAlignment="Bottom" Margin="0,0,0,20"/>
                                                 <TextBlock Text="{Binding DayLabel}" Foreground="{Binding LabelBrush}" FontWeight="{Binding LabelWeight}" FontSize="12.5" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                                             </Grid>
                                         </DataTemplate>
                                     </ItemsControl.ItemTemplate>
                                 </ItemsControl>
                            </StackPanel>
                        </components:GlassPanel>

                    </StackPanel>

                    <!-- Right Column details -->
                    <StackPanel Grid.Column="2" Orientation="Vertical">
                        <!-- System Integration and Settings -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- System Integration card -->
                            <components:GlassPanel Grid.Column="0" CornerRadius="12" Padding="20">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="SYSTEM INTEGRATION" Foreground="{StaticResource OnSurfaceVariantBrushHigh}" FontSize="12" FontWeight="Bold"  Margin="0,0,0,16"/>
                                    <Button Command="{Binding OpenDirectoryCommand}" Style="{StaticResource SystemIntegrationButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Path Grid.Column="0" Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" 
                                                  Fill="{StaticResource OnSurfaceVariantBrushHigh}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                                             <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                                 <TextBlock Text="Executable Directory" Foreground="White" FontSize="13.5" FontWeight="SemiBold"/>
                                                 <TextBlock Text="{Binding ExePath}" Foreground="#B3C7C4D8" FontSize="13" FontFamily="Cascadia Mono, Consolas" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                             </StackPanel>
                                             <!-- Arrow right -->
                                             <Path Grid.Column="2" Data="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z" Fill="{StaticResource OnSurfaceVariantBrushMedium}" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"/>
                                         </Grid>
                                     </Button>
                                 </StackPanel>
                             </components:GlassPanel>

                             <!-- Settings Gear Button -->
                             <Button Grid.Column="1" 
                                     Style="{StaticResource OrangeGearButtonStyle}"
                                     Width="52" Height="52"
                                     Margin="12,0,0,20"
                                     VerticalAlignment="Bottom"
                                     Click="OnOptionsClick">
                                 <Path Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" 
                                       Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" 
                                       Width="22" Height="22" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                             </Button>
                        </Grid>
 
                         <!-- Launch Arguments Customizer -->
                         <components:GlassPanel CornerRadius="12" Padding="20" Margin="0,20,0,0">
                             <StackPanel Orientation="Vertical">
                                  <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                      <Path Data="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z" 
                                            Fill="{StaticResource OnSurfaceVariantBrushHigh}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                      <TextBlock Text="LAUNCH ARGUMENTS" Foreground="{StaticResource OnSurfaceVariantBrushHigh}" FontSize="12" FontWeight="Bold"  Margin="8,0,0,0" VerticalAlignment="Center"/>
                                  </StackPanel>
 
                                 <!-- Custom parameter input bar -->
                                 <Grid Margin="0,4,0,0">
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="*"/>
                                         <ColumnDefinition Width="Auto"/>
                                     </Grid.ColumnDefinitions>
                                     <!-- Editable Text parameter box -->
                                     <TextBox Grid.Column="0" 
                                              Style="{StaticResource SunkenSearchBox}"
                                              Text="{Binding LaunchArguments, UpdateSourceTrigger=PropertyChanged}"
                                              Tag="Add launch arguments..."
                                              CaretBrush="{StaticResource PrimaryBrush}"
                                              FontSize="13" 
                                              FontFamily="{StaticResource MonospaceFont}" 
                                              VerticalAlignment="Center"/>
                                     <!-- Save chevron disk -->
                                     <Button Grid.Column="1" 
                                             Command="{Binding SaveArgsCommand}" 
                                             Style="{StaticResource SaveArgsButtonStyle}"
                                             Margin="8,0,0,0"/>
                                 </Grid>
                             </StackPanel>
                         </components:GlassPanel>
                     </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
