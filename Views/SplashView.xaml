<UserControl x:Class="Lunex.Views.SplashView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    <UserControl.Resources>
        <!-- Rotation Storyboard for loading circle -->
        <Storyboard x:Key="RotateLoader" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LoaderRotate" 
                             Storyboard.TargetProperty="Angle" 
                             From="0" To="360" Duration="0:0:1.4"/>
        </Storyboard>

        <!-- Pulsing Logo Storyboard -->
        <Storyboard x:Key="PulseLogo" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="LogoScale" 
                             Storyboard.TargetProperty="ScaleX" 
                             From="1.0" To="1.05" Duration="0:0:1.0" DecelerationRatio="0.5"/>
            <DoubleAnimation Storyboard.TargetName="LogoScale" 
                             Storyboard.TargetProperty="ScaleY" 
                             From="1.0" To="1.05" Duration="0:0:1.0" DecelerationRatio="0.5"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid Background="#131316">
        <!-- Background Ambient Light Spheres -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            <Ellipse Width="350" Height="350" Fill="#034F46E5" Opacity="0.4">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="300" Height="300" Fill="#037C03D3" Opacity="0.3" Margin="50,50,0,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>

        <!-- Main Loading Stack -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Pulsing Cyber Logo + Spinning Outer Loader -->
            <Grid Width="200" Height="200" HorizontalAlignment="Center">
                <Grid.RenderTransform>
                    <ScaleTransform x:Name="LogoScale" CenterX="100" CenterY="100"/>
                </Grid.RenderTransform>

                <!-- Vector Loader (glowing rotating path arc) -->
                <Ellipse Width="160" Height="160" StrokeThickness="3" Stroke="#11C3C0FF"/>
                <Path x:Name="GlowArc" Width="160" Height="160" 
                      Data="M 30 130 A 70 70 0 1 1 130 130"
                      StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                    <Path.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4F46E5" Offset="0.0" />
                            <GradientStop Color="#7C03D3" Offset="0.5" />
                            <GradientStop Color="Transparent" Offset="1.0" />
                        </LinearGradientBrush>
                    </Path.Stroke>
                    <Path.RenderTransform>
                        <RotateTransform x:Name="LoaderRotate" CenterX="80" CenterY="80"/>
                    </Path.RenderTransform>
                </Path>


                <!-- Hexagonal Procedural Emblem -->
                <Grid Width="90" Height="90" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Glowing Background Shadow -->
                    <Border CornerRadius="45" Background="#14C3C0FF">
                        <Border.Effect>
                            <DropShadowEffect Color="#C3C0FF" BlurRadius="25" Opacity="0.2"/>
                        </Border.Effect>
                    </Border>
                    <!-- Outer Hexagon -->
                    <Polygon Points="45,0 84,22.5 84,67.5 45,90 6,67.5 6,22.5" 
                             Stroke="#40C3C0FF" StrokeThickness="2.5" Fill="Transparent"/>
                    <!-- Letter N Futuristic Path -->
                    <Path Data="M 32,60 V 30 L 58,60 V 30" 
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          StrokeThickness="5" Margin="0,0,0,0">
                        <Path.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#C3C0FF" Offset="0.0"/>
                                <GradientStop Color="#DDB8FF" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Path.Stroke>
                        <Path.Effect>
                            <DropShadowEffect Color="#C3C0FF" BlurRadius="6" Opacity="0.6" ShadowDepth="0"/>
                        </Path.Effect>
                    </Path>
                    <!-- Small vertex neon glowing dots -->
                    <Ellipse Width="6" Height="6" Fill="#4EDEA3" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="29,27,0,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#4EDEA3" BlurRadius="8" Opacity="0.8" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <Ellipse Width="6" Height="6" Fill="#4EDEA3" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,29,27">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#4EDEA3" BlurRadius="8" Opacity="0.8" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>
            </Grid>

            <!-- Brand Typography -->
            <TextBlock Text="LUNEX" 
                       Foreground="White" 
                       FontSize="28" 
                       FontWeight="Black" 
                        
                       HorizontalAlignment="Center" 
                       Margin="0,48,0,0"/>

            <!-- System Terminal Typewriter Console -->
            <TextBlock x:Name="ConsoleBlock"
                       Text="INITIALIZING SYSTEM CORES..." 
                       Foreground="#7FC7C4D8" 
                       FontFamily="{StaticResource MonospaceFont}" 
                       FontSize="11" 
                       HorizontalAlignment="Center" 
                       Margin="0,16,0,0" 
                       />
        </StackPanel>

        <!-- Bottom Company Brand -->
        <TextBlock Text="N E X U S   R E A L M" 
                   Foreground="#26C7C4D8" 
                   FontSize="10" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,32"/>
    </Grid>
</UserControl>
