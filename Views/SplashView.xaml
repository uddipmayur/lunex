<UserControl x:Class="Lunex.Views.SplashView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    <UserControl.Resources>
        <!-- Rotation Storyboard for loading circle -->
        <Storyboard x:Key="RotateLoader" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LoaderRotate" 
                             Storyboard.TargetProperty="Angle" 
                             From="0" To="360" Duration="0:0:1.4"/>
        </Storyboard>

        <!-- Pulsing Logo Storyboard -->
        <Storyboard x:Key="PulseLogo" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="LogoScale" 
                             Storyboard.TargetProperty="ScaleX" 
                             From="1.0" To="1.05" Duration="0:0:1.0" DecelerationRatio="0.5"/>
            <DoubleAnimation Storyboard.TargetName="LogoScale" 
                             Storyboard.TargetProperty="ScaleY" 
                             From="1.0" To="1.05" Duration="0:0:1.0" DecelerationRatio="0.5"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <!-- Main Loading Stack -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Pulsing Logo + Spinning Outer Loader -->
            <Grid Width="200" Height="200" HorizontalAlignment="Center">
                <Grid.RenderTransform>
                    <ScaleTransform x:Name="LogoScale" CenterX="100" CenterY="100"/>
                </Grid.RenderTransform>
 
                <!-- Vector Loader (Flat rotating path arc) -->
                <Ellipse Width="160" Height="160" StrokeThickness="3" Stroke="{StaticResource PrimaryBrushLow}"/>
                <Path x:Name="GlowArc" Width="160" Height="160" 
                      Data="M 30 130 A 70 70 0 1 1 130 130"
                      StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Stroke="{StaticResource PrimaryBrush}">
                    <Path.RenderTransform>
                        <RotateTransform x:Name="LoaderRotate" CenterX="80" CenterY="80"/>
                    </Path.RenderTransform>
                </Path>
 
                <!-- Hexagonal Emblem (Flat Design) -->
                <Grid Width="90" Height="90" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Flat Background Circle -->
                    <Border CornerRadius="45" Background="#161616" BorderBrush="#2A2A2A" BorderThickness="1"/>
                    <!-- Outer Hexagon -->
                    <Polygon Points="45,0 84,22.5 84,67.5 45,90 6,67.5 6,22.5" 
                             Stroke="{StaticResource PrimaryBrush}" StrokeThickness="2.5" Fill="Transparent"/>
                    <!-- Letter N Path (Flat Design) -->
                    <Path Data="M 32,60 V 30 L 58,60 V 30" 
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          StrokeThickness="5" Margin="0,0,0,0"
                          Stroke="{StaticResource PrimaryBrush}"/>
                    <!-- Small vertex flat dots -->
                    <Ellipse Width="6" Height="6" Fill="{StaticResource PrimaryBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="29,27,0,0"/>
                    <Ellipse Width="6" Height="6" Fill="{StaticResource PrimaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,29,27"/>
                </Grid>
            </Grid>

            <!-- Brand Typography -->
            <TextBlock Text="LUNEX" 
                       Foreground="{StaticResource OnSurfaceBrush}" 
                       FontSize="28" 
                       FontWeight="Black" 
                        
                       HorizontalAlignment="Center" 
                       Margin="0,48,0,0"/>

            <!-- System Terminal Typewriter Console -->
            <TextBlock x:Name="ConsoleBlock"
                       Text="INITIALIZING SYSTEM CORES..." 
                       Foreground="{StaticResource OnSurfaceVariantBrushHigh}" 
                       FontFamily="{StaticResource MonospaceFont}" 
                       FontSize="14" 
                       HorizontalAlignment="Center" 
                       Margin="0,16,0,0" 
                       />
        </StackPanel>

        <!-- Bottom Company Brand -->
        <TextBlock Text="N E X U S   R E A L M" 
                   Foreground="{StaticResource OnSurfaceVariantBrushLow}" 
                   FontSize="12" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,32"/>
    </Grid>
</UserControl>
