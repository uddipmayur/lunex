<Window x:Class="Lunex.Views.ModernDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Lunex Message"
        Height="220" Width="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- Scale and fade in animation on load -->
        <Storyboard x:Key="OnLoadedStoryboard">
            <DoubleAnimation Storyboard.TargetName="DialogBorder" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="DialogScale" Storyboard.TargetProperty="ScaleX"
                             From="0.8" To="1.0" Duration="0:0:0.3" DecelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetName="DialogScale" Storyboard.TargetProperty="ScaleY"
                             From="0.8" To="1.0" Duration="0:0:0.3" DecelerationRatio="0.8"/>
        </Storyboard>

        <!-- Scale and fade out animation on close -->
        <Storyboard x:Key="OnClosingStoryboard">
            <DoubleAnimation Storyboard.TargetName="DialogBorder" Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.2" AccelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetName="DialogScale" Storyboard.TargetProperty="ScaleX"
                             To="0.8" Duration="0:0:0.2" AccelerationRatio="0.8"/>
            <DoubleAnimation Storyboard.TargetName="DialogScale" Storyboard.TargetProperty="ScaleY"
                             To="0.8" Duration="0:0:0.2" AccelerationRatio="0.8"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource OnLoadedStoryboard}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border x:Name="DialogBorder" CornerRadius="16" BorderBrush="#1DFFFFFF" BorderThickness="1.5" Background="{StaticResource CyberBackgroundGradient}" ClipToBounds="True" RenderTransformOrigin="0.5,0.5" Opacity="0">
        <Border.RenderTransform>
            <ScaleTransform x:Name="DialogScale" ScaleX="0.8" ScaleY="0.8"/>
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <!-- Title Row -->
                <RowDefinition Height="Auto"/>
                <!-- Message Row -->
                <RowDefinition Height="*"/>
                <!-- Button Row -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Drag Bar -->
            <Grid Grid.Row="0" Margin="24,20,24,8" MouseLeftButtonDown="DragWindow">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <!-- Glowing shield or notification decal -->
                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" 
                          Fill="{StaticResource PrimaryBrush}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TitleText" Text="NOTIFICATION" Foreground="{StaticResource PrimaryBrush}" FontSize="13" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Click="CloseDialog" Style="{StaticResource ModalCloseButtonStyle}">
                    <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                          Width="10" Height="10" Stretch="Uniform"/>
                </Button>
            </Grid>

            <!-- Message Block -->
            <TextBlock Grid.Row="1" x:Name="MessageText" Text="Profile settings saved successfully." Foreground="White" FontSize="15" Margin="24,12,24,18" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" LineHeight="20"/>

            <!-- Action buttons container -->
            <Border Grid.Row="2" Background="#0CFFFFFF" BorderBrush="#0BFFFFFF" BorderThickness="0,1,0,0" Padding="24,16">
                <Grid>
                    <!-- OK Button -->
                    <Button x:Name="OkButton" Click="CloseDialog" Width="120" Height="36" Style="{StaticResource NeonButtonStyle}" HorizontalAlignment="Center">
                        <TextBlock Text="OK" FontSize="13" FontWeight="Bold" />
                    </Button>
                    <!-- Yes / No Buttons -->
                    <UniformGrid x:Name="ConfirmButtons" Columns="2" Width="260" Visibility="Collapsed">
                        <Button Click="Yes_Click" Height="36" Style="{StaticResource NeonButtonStyle}" Margin="0,0,8,0">
                            <TextBlock Text="YES" FontSize="13" FontWeight="Bold" />
                        </Button>
                        <Button Click="No_Click" Height="36" Style="{StaticResource NeonButtonStyle}" Margin="8,0,0,0">
                            <TextBlock Text="NO" FontSize="13" FontWeight="Bold" />
                        </Button>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
