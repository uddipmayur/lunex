<Window x:Class="Lunex.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:components="clr-namespace:Lunex.Components"
        xmlns:vm="clr-namespace:Lunex.ViewModels"
        xmlns:services="clr-namespace:Lunex.Services"
        mc:Ignorable="d"
        Title="Lunex" 
        Icon="app.ico"
        FontFamily="Segoe UI"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="1024"
        WindowStyle="SingleBorderWindow" 
        AllowsTransparency="False" 
        Background="#131316"
        WindowStartupLocation="CenterScreen">
    
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" 
                      CornerRadius="0" 
                      CaptionHeight="64" 
                      UseAeroCaptionButtons="False" 
                      ResizeBorderThickness="8"/>
    </WindowChrome.WindowChrome>
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        
        <!-- Windows Chrome Control Buttons Style -->
        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="16" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#15FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseChromeButtonStyle" TargetType="Button" BasedOn="{StaticResource ChromeButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33FF5555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <!-- Main Outer visual shell -->
    <Border x:Name="MainShellBorder" CornerRadius="16" Background="{StaticResource CyberBackgroundGradient}" BorderBrush="#1CFFFFFF" BorderThickness="1" ClipToBounds="True" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
        </Border.RenderTransform>
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Navigation Drawer -->
                <ColumnDefinition Width="Auto"/>
                <!-- Main Canvas Content -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>



            <!-- Sidebar Navigation panel -->
            <components:LunexSidebar Grid.Column="0" x:Name="SidebarNavPanel" Width="260"
                                     WindowChrome.IsHitTestVisibleInChrome="True"
                                     Visibility="{Binding IsMainUiActive, Converter={StaticResource BoolToVisConverter}}"/>

            <!-- Main Panel containing Top Header NavBar and Content Canvas -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <!-- Top titlebar search bar height -->
                    <RowDefinition Height="Auto"/>
                    <!-- Main view swap canvas -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Draggable Title Bar / Search panel -->
                <Grid Grid.Row="0" Height="64" Background="Transparent"
                      Visibility="{Binding IsMainUiActive, Converter={StaticResource BoolToVisConverter}}">
                    <Grid.ColumnDefinitions>
                        <!-- Draggable title / Search -->
                        <ColumnDefinition Width="*"/>
                        <!-- Windows chrome action controls -->
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="24,0,0,0">
                        <TextBlock Text="LUNEX SYSTEM" Foreground="#B3C7C4D8" FontSize="11" FontWeight="Bold"  VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Windows title bar controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center" MouseLeftButtonDown="SuppressDrag"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource ChromeButtonStyle}" Click="MinimizeWindow">
                            <Path Data="M20 19H4v-2h16v2z" Fill="White" Width="12" Height="12" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ChromeButtonStyle}" Click="MaximizeWindow" Margin="4,0,0,0">
                            <Path Data="M4 4h16v16H4V4zm2 2v12h12V6H6z" Fill="White" Width="12" Height="12" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource CloseChromeButtonStyle}" Click="CloseWindow" Margin="4,0,0,0">
                            <!-- X Sign -->
                            <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" Fill="White" Width="12" Height="12" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Center visual View canvas -->
                <components:CachedContentControl Grid.Row="1" Content="{Binding CurrentViewModel}" ClipToBounds="True"/>
            </Grid>
        </Grid>
    </Border>
</Window>
