<Window x:Class="Lunex.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:components="clr-namespace:Lunex.Components"
        xmlns:vm="clr-namespace:Lunex.ViewModels"
        xmlns:services="clr-namespace:Lunex.Services"
        xmlns:local="clr-namespace:Lunex"
        mc:Ignorable="d"
        Title="Lunex" 
        Icon="app.ico"
        FontFamily="Segoe UI"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="1024"
        WindowStyle="SingleBorderWindow" 
        AllowsTransparency="False" 
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" 
                      CornerRadius="0" 
                      CaptionHeight="64" 
                      UseAeroCaptionButtons="False" 
                      ResizeBorderThickness="8"/>
    </WindowChrome.WindowChrome>
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        
        <!-- Steam Top Navigation Button Style -->
        <Style x:Key="TopNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                <!-- Active Underline effect -->
                                <Rectangle x:Name="activeIndicator" Height="3" VerticalAlignment="Bottom" Fill="{StaticResource PrimaryBrush}" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Active">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="activeIndicator" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Windows Chrome Control Buttons Style -->
        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="16" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#15FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
 
        <Style x:Key="CloseChromeButtonStyle" TargetType="Button" BasedOn="{StaticResource ChromeButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33FF5555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Cloud Status Icon Button Style -->
        <Style x:Key="TopNavCloudButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="18" Background="Transparent" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#15FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Steam Top Navigation Icon Button Style (Settings) -->
        <Style x:Key="TopNavIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="18" Background="Transparent" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#15FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <!-- Highlight orange if active view is settings -->
                            <DataTrigger Binding="{Binding ActiveView}" Value="settings">
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="#10D97757"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Profile Navigation Circle Button Style -->
        <Style x:Key="ProfileNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="18" Background="Transparent" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#15FFFFFF"/>
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <!-- Highlight if active view is profile -->
                            <DataTrigger Binding="{Binding ActiveView}" Value="profile">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="#15D97757"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
 
    </Window.Resources>
 
    <!-- Main Outer visual shell -->
    <Border x:Name="MainBorder" CornerRadius="16" Background="{StaticResource CyberBackgroundGradient}" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" ClipToBounds="True" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <!-- Top Header Row -->
                <RowDefinition Height="Auto"/>
                <!-- Main Canvas Content Area -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Draggable Title Bar / Navigation panel (extreme left to right) -->
            <Grid Grid.Row="0" Height="64" Background="Transparent"
                  Visibility="{Binding IsMainUiActive, Converter={StaticResource BoolToVisConverter}}">
                <Grid.ColumnDefinitions>
                    <!-- Logo / Left-aligned Nav Tabs -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Draggable gap (or stretchable area) -->
                    <ColumnDefinition Width="*"/>
                    <!-- Right-aligned Nav Tabs (Settings, Profile) -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Windows chrome action controls -->
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="24,0,0,0" WindowChrome.IsHitTestVisibleInChrome="True">
                    <!-- logo or branding -->
                    <TextBlock Text="LUNEX" Foreground="{StaticResource PrimaryBrush}" FontSize="20" FontWeight="Black" VerticalAlignment="Center" Margin="0,0,40,0" local:TypographyHelper.CharacterSpacing="100"/>
                    
                    <!-- Navigation Menu Items -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Library -->
                        <Button Content="LIBRARY" Command="{Binding NavigateCommand}" CommandParameter="library" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TopNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveView}" Value="library">
                                            <Setter Property="Tag" Value="Active"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        
                        <!-- Music -->
                        <Button Content="MUSIC" Command="{Binding NavigateCommand}" CommandParameter="music" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TopNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveView}" Value="music">
                                            <Setter Property="Tag" Value="Active"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Stats -->
                        <Button Content="STATS" Command="{Binding NavigateCommand}" CommandParameter="stats" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TopNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveView}" Value="stats">
                                            <Setter Property="Tag" Value="Active"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Right-aligned Settings and Profile Icons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0" WindowChrome.IsHitTestVisibleInChrome="True">
                    <!-- Cloud Status Button -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="{Binding CloudStatusText}" 
                                   Foreground="#9CA3AF" 
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" 
                                   Margin="0,0,8,0"
                                   Visibility="{Binding ShowCloudStatusText, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Command="{Binding ShowCloudStatusCommand}" Style="{StaticResource TopNavCloudButtonStyle}">
                            <Grid Width="20" Height="20">
                                <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z" 
                                      Fill="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                                      Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="1,2,1,0"/>
                                
                                <!-- Green Dot for Online -->
                                <Ellipse Width="6" Height="6" Fill="#4CAF50" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-1,-1"
                                         Visibility="{Binding IsOnline, Converter={StaticResource BoolToVisConverter}}"/>
                                
                                <!-- Strikethrough for Offline -->
                                <Path Data="M1 1 L19 19" Stroke="#FF5555" StrokeThickness="2" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <!-- Settings Icon Button -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="settings" Margin="0,0,16,0" Style="{StaticResource TopNavIconButtonStyle}">
                        <Path Data="M19.43 12.98c.04-.32.07-.64.07-.98s-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98s.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z" 
                              Fill="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                              Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Profile Circle Button -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="profile" Style="{StaticResource ProfileNavButtonStyle}">
                        <Grid Width="32" Height="32">
                            <!-- Circular Fallback Avatar (Initials) -->
                            <Border x:Name="FallbackBorder" 
                                    CornerRadius="16" 
                                    Background="#222" 
                                    BorderBrush="{Binding Path=BorderBrush, RelativeSource={RelativeSource AncestorType=Button}}" 
                                    BorderThickness="1.5">
                                <TextBlock Text="{Binding ProfileInitials}" 
                                           Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                                           FontSize="15" 
                                           FontWeight="Black" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <!-- Circular Custom Image Avatar -->
                            <Border x:Name="AvatarBorder" 
                                    CornerRadius="16" 
                                    BorderBrush="{Binding Path=BorderBrush, RelativeSource={RelativeSource AncestorType=Button}}" 
                                    BorderThickness="1.5"
                                    Visibility="{Binding ProfileHasDp, Converter={StaticResource BoolToVisConverter}}"
                                    RenderOptions.BitmapScalingMode="HighQuality">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding ProfileDpPath}" Stretch="UniformToFill"/>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Windows title bar controls -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center" MouseLeftButtonDown="SuppressDrag"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource ChromeButtonStyle}" Click="MinimizeWindow">
                        <Path Data="M20 19H4v-2h16v2z" Fill="White" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                    <Button Style="{StaticResource ChromeButtonStyle}" Click="MaximizeWindow" Margin="4,0,0,0">
                        <Path Data="M4 4h16v16H4V4zm2 2v12h12V6H6z" Fill="White" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                    <Button Style="{StaticResource CloseChromeButtonStyle}" Click="CloseWindow" Margin="4,0,0,0">
                        <!-- X Sign -->
                        <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" Fill="White" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main Content Area Grid: Sidebar & Content Canvas start from below the header -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!-- Sidebar Column -->
                    <ColumnDefinition x:Name="SidebarColumn">
                        <ColumnDefinition.Style>
                            <Style TargetType="ColumnDefinition">
                                <Setter Property="Width" Value="260"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.ShowLibrarySidebar, ElementName=RootWindow}" Value="False">
                                        <Setter Property="Width" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ColumnDefinition.Style>
                    </ColumnDefinition>
                    <!-- Content Column -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- atmosphere repeating diagonal lines overlay -->
                <Rectangle Grid.ColumnSpan="2" Fill="{StaticResource DiagonalLinesPatternBrush}" Opacity="0.03" IsHitTestVisible="False"/>

                <!-- Shared Library Sidebar panel -->
                <components:LunexSidebar Grid.Column="0" x:Name="SidebarNavPanel"
                                         WindowChrome.IsHitTestVisibleInChrome="True"
                                         DataContext="{Binding LibraryVm}"
                                         Visibility="{Binding DataContext.ShowLibrarySidebar, ElementName=RootWindow, Converter={StaticResource BoolToVisConverter}}"/>

                <!-- Center visual View canvas -->
                <components:CachedContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" ClipToBounds="True"/>
            </Grid>
        </Grid>
    </Border>
</Window>
